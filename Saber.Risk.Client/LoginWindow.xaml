<Window x:Class="Saber.Risk.Client.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Saber.Risk.Client"
        mc:Ignorable="d"
        Title="SABER RISK - Login" Height="450" Width="350"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen">

    <Border Background="#161B22" CornerRadius="20" BorderBrush="#30363D" BorderThickness="1">
        <Grid Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,20">
                <TextBlock Text="SABER" Foreground="#58A6FF" FontSize="28" FontWeight="Black"/>
                <TextBlock Text="RISK MONITOR" Foreground="#8B949E" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,-5,0,0"/>
            </StackPanel>

            <TextBlock Grid.Row="1" Text="Sign in to continue" Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,30"/>

            <StackPanel Grid.Row="2">
                <TextBlock Text="USERNAME" Foreground="#8B949E" FontSize="10" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="UsernameBox" Background="#0D1117" Foreground="White" BorderBrush="#30363D" Padding="10" Margin="0,0,0,20"/>

                <TextBlock Text="PASSWORD" Foreground="#8B949E" FontSize="10" FontWeight="Bold" Margin="0,0,0,5"/>
                <PasswordBox x:Name="PasswordBox" Background="#0D1117" Foreground="White" BorderBrush="#30363D" Padding="10"/>

                <TextBlock x:Name="ErrorLabel" Text="Invalid credentials" Foreground="#F85149" FontSize="11" Margin="0,10,0,0" Visibility="Collapsed"/>
            </StackPanel>

            <Button Grid.Row="3" Content="LOGIN" Click="LoginButton_Click"
                    Background="#238636" Foreground="White" FontWeight="Bold" Padding="15" 
                    BorderThickness="0" Cursor="Hand" Margin="0,20,0,0">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="8"/>
                    </Style>
                </Button.Resources>
            </Button>
        </Grid>
    </Border>
</Window>