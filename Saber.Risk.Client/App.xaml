<Application x:Class="Saber.Risk.Client.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Saber.Risk.Client">
    <!-- USUNIĘTO StartupUri="MainWindow.xaml" -->
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- 1. TO JEST TWOJA PACZKA STARTOWA (LightMode) -->
                <ResourceDictionary>
                    <SolidColorBrush x:Key="WindowBackground" Color="#F0F2F5"/>
                    <SolidColorBrush x:Key="CardBackground" Color="White"/>
                    <SolidColorBrush x:Key="HeaderBrush" Color="#24292E"/>
                    <SolidColorBrush x:Key="TextBrush" Color="#1B1F23"/>
                    <SolidColorBrush x:Key="SecondaryTextBrush" Color="#666666"/>
                </ResourceDictionary>
            </ResourceDictionary.MergedDictionaries>

            <!-- 2. Definicja Motywu Jasnego -->
            <ResourceDictionary x:Key="LightMode">
                <SolidColorBrush x:Key="WindowBackground" Color="#F0F2F5"/>
                <SolidColorBrush x:Key="CardBackground" Color="White"/>
                <SolidColorBrush x:Key="HeaderBrush" Color="#24292E"/>
                <SolidColorBrush x:Key="TextBrush" Color="#1B1F23"/>
                <SolidColorBrush x:Key="SecondaryTextBrush" Color="#666666"/>
            </ResourceDictionary>

            <!-- 3. Definicja Motywu Ciemnego -->
            <ResourceDictionary x:Key="DarkMode">
                <SolidColorBrush x:Key="WindowBackground" Color="#0D1117"/>
                <SolidColorBrush x:Key="CardBackground" Color="#161B22"/>
                <SolidColorBrush x:Key="HeaderBrush" Color="#010409"/>
                <SolidColorBrush x:Key="TextBrush" Color="#C9D1D9"/>
                <SolidColorBrush x:Key="SecondaryTextBrush" Color="#8B949E"/>
            </ResourceDictionary>
        </ResourceDictionary>
    </Application.Resources>
</Application>